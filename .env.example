# Example .env for local development — DO NOT COMMIT real secrets
# Copy to .env and fill values, or set repository secrets for CI deploy.

# Basic auth (change before production)
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=admin

# Encryption key (must be 32+ chars). Generate with:
# openssl rand -base64 32
N8N_ENCRYPTION_KEY=
